name = "tw-stock-ai-scheduler"
main = "worker.js"
compatibility_date = "2026-05-22"

[triggers]
crons = [
  "30 20 * * 0-4", # 04:30 Asia/Taipei Mon-Fri dashboard
  "0 21 * * 0-4",  # 05:00 Asia/Taipei Mon-Fri dashboard backup
  "0 0 * * 1-5",   # 08:00 Asia/Taipei Mon-Fri Telegram
  "15 0 * * 1-5",  # 08:15 Asia/Taipei Mon-Fri Telegram backup
]
